#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура РассчитатьСуммуСтроки(ТекущиеДанные)
	
	КоэффициентСкидки = 1 - ТекущиеДанные.Скидка / 100;
	ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество * КоэффициентСкидки;
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСуммуДокумента()
	
	Объект.СуммаДокумента = Объект.Товары.Итог("Сумма") + Объект.Услуги.Итог("Сумма");
	
КонецПроцедуры

&НаСервере
Процедура ДобавлениеЭлементов()
	
	//++ Филиппова

	//Добавление поля реквизита "до_СогласованнаяСкидка"  и команды "ПересчитатьТаблицу"
	ГруппаДобавления = Элементы.ГруппаШапкаЛево;
	НоваяГруппа = Элементы.Добавить("ГруппаСогласованияСкидки", Тип("ГруппаФормы"), ГруппаДобавления); 
	НоваяГруппа.Вид = ВидГруппыФормы.ОбычнаяГруппа;  
	НоваяГруппа.ОтображатьЗаголовок = Ложь;
	НоваяГруппа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	
	НовыйЭлемент = Элементы.Добавить("до_СогласованнаяСкидка", Тип("ПолеФормы"), НоваяГруппа);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным = "Объект.до_СогласованнаяСкидка"; 
	НовыйЭлемент.УстановитьДействие("ПриИзменении", "до_СогласованнаяСкидкаПриИзменении");
	
	НоваяКоманда = Команды.Добавить("ПересчитатьТаблицу");
	НоваяКоманда.Заголовок = "Пересчитать таблицу";
	НоваяКоманда.Действие = "ПересчитатьТаблицу"; 
	
	НовыйЭлемент = Элементы.Добавить("ПересчитатьТаблицу", Тип("КнопкаФормы"),НоваяГруппа);
	НовыйЭлемент.Заголовок = "Пересчитать таблицу";
	НовыйЭлемент.ИмяКоманды = "ПересчитатьТаблицу";  
	
    //-- Филиппова
    
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьСкидукуВТаблице(Товары)
	
	//++ Филиппова
	Для каждого СтрокаТЧ Из Объект[Товары] Цикл			
		РассчитатьСуммуСтроки(СтрокаТЧ);
	КонецЦикла;  
	
	РассчитатьСуммуДокумента();
	//-- Филиппова

КонецПроцедуры

&НаКлиенте
Асинх Процедура ЗадатьВопросАсинх()
	
	//++ Филиппова
   Ответ = Ждать ВопросАсинх("Изменен процент скидки. Пересчитать таблицы товаров и услуг?",РежимДиалогаВопрос.ДаНет);
	
   Если Ответ = КодВозвратаДиалога.Да Тогда 
   	
	   ЗаполнитьСкидкуВТабличнойЧасти("Товары");   	
	   ЗаполнитьСкидкуВТабличнойЧасти("Услуги");   	
	   
       ПересчитатьСкидукуВТаблице("Товары");	   
	   ПересчитатьСкидукуВТаблице("Услуги");
	   
   КонецЕсли; 
   //-- Филиппова

КонецПроцедуры    

&НаКлиенте
Процедура ЗаполнитьСкидкуВТабличнойЧасти(Товары)
	
	//++ Филиппова
	Для каждого СтрокаТЧ Из Объект[Товары] Цикл			
		СтрокаТЧ.Скидка = Объект.до_СогласованнаяСкидка;
	КонецЦикла;  
	//-- Филиппова

КонецПроцедуры


