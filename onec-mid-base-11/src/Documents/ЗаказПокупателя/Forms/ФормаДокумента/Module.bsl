// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

&НаКлиенте
Процедура ПересчитатьТаблицу(Команда)
	
	//++ Филиппова Перерасчет скидки в таблицах Товары и Услуги
	ЗаполнитьСкидкуВТабличнойЧасти("Товары");   		
	ЗаполнитьСкидкуВТабличнойЧасти("Услуги"); 
	  	
	ПересчитатьСкидукуВТаблице("Товары");
	ПересчитатьСкидукуВТаблице("Услуги"); 	                  
	//-- Филиппова

КонецПроцедуры

&НаКлиенте
Процедура до_СогласованнаяСкидкаПриИзменении(Элемент)
	
	//++ Филиппова 
	//Вывести Вопрос о расчете скидки
	Если ЗначениеЗаполнено(Объект.Товары) или ЗначениеЗаполнено(Объект.Услуги) Тогда
		
		ЗадатьВопросАсинх();	
	
	КонецЕсли;
	// Филиппова
	
КонецПроцедуры 

